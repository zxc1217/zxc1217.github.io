---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE } from '../../config';
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft);
  const sorted = posts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
  return sorted.map((post, i) => ({
    params: { slug: post.slug },
    props: {
      post,
      prev: sorted[i + 1] ?? null,
      next: sorted[i - 1] ?? null,
    },
  }));
}

interface Props {
  post: CollectionEntry<'posts'>;
  prev: CollectionEntry<'posts'> | null;
  next: CollectionEntry<'posts'> | null;
}

const { post, prev, next } = Astro.props;
const { Content, headings } = await post.render();

// 只取 h2 作为目录
const h2Headings = headings.filter(h => h.depth === 2);

const zhNum = ['零','一','二','三','四','五','六','七','八','九','十'];
const zhWeek = ['周日','周一','周二','周三','周四','周五','周六'];
function zhDay(n: number): string {
  if (n <= 10) return zhNum[n] + '日';
  if (n < 20) return '十' + (n === 10 ? '' : zhNum[n - 10]) + '日';
  if (n === 20) return '二十日';
  if (n < 30) return '二十' + zhNum[n - 20] + '日';
  if (n === 30) return '三十日';
  return '三十一日';
}
function zhMonth(m: number): string { return zhNum[m] + '月'; }
function formatDate(d: Date, mood?: string): string {
  const m = zhMonth(d.getMonth() + 1);
  const day = zhDay(d.getDate());
  const w = zhWeek[d.getDay()];
  return `${m}${day}，${w}${mood ? '，' + mood : ''}`;
}
---

<BaseLayout title={post.data.title} description={post.data.note} activeNav="writing">
  <!-- 阅读进度条（固定在页面顶部） -->
  <div class="read-progress"><div class="read-progress-fill" id="progress"></div></div>

  <div class="article-wrap">
    {h2Headings.length > 0 && (
      <nav class="toc" aria-label="目录">
        <div class="toc-label">目录</div>
        <ul>
          {h2Headings.map(h => (
            <li><a href={`#${h.slug}`} data-target={h.slug}>{h.text}</a></li>
          ))}
        </ul>
      </nav>
    )}

    <article class="article">
      <a href="/writing/" class="back">← 回到全部文章</a>

      <header class="head">
        <div class="kicker">{formatDate(post.data.date, post.data.mood)}</div>
        <h1 class="title">{post.data.title}</h1>
        <div class="meta">
          <span class="tag">{post.data.tag}</span>
          <span class="sep">·</span>
          {post.data.readTime && <><span>{post.data.readTime} 分钟阅读</span></>}
        </div>
      </header>

      {post.data.note && (
        <div class="note">{post.data.note}</div>
      )}

      <div class="body">
        <Content />
      </div>

      <div class="end">
        <span class="end-mark"></span>
      </div>

      <div class="signoff">
        如果你读到了这里，谢谢你 —<br/>
        <span class="signoff-name">{SITE.author}</span>
      </div>

      <nav class="prev-next">
        {prev ? (
          <a class="prev-next-side prev" href={`/writing/${prev.slug}/`}>
            <div class="label">← 上一篇</div>
            <div class="pn-title">{prev.data.title}</div>
          </a>
        ) : <span></span>}
        {next ? (
          <a class="prev-next-side next" href={`/writing/${next.slug}/`}>
            <div class="label">下一篇 →</div>
            <div class="pn-title">{next.data.title}</div>
          </a>
        ) : <span></span>}
      </nav>
    </article>
  </div>
</BaseLayout>

<style>
  .read-progress {
    position: fixed; top: 0; left: 0; right: 0;
    height: 2px; background: transparent;
    z-index: 100;
  }
  .read-progress-fill {
    height: 100%; width: 0%;
    background: var(--brand);
    transition: width 0.1s;
  }

  .article-wrap {
    max-width: 820px; margin: 0 auto;
    padding: 0 1rem; position: relative;
    font-family: var(--font-sans);
  }

  /* 浮动目录 */
  .toc {
    position: fixed;
    left: max(20px, calc(50% - 440px));
    top: 120px;
    width: 180px;
    font-size: 12px;
    display: none;
  }
  @media (min-width: 1080px) {
    .toc { display: block; }
  }
  .toc-label {
    font-family: var(--font-serif); font-style: italic;
    color: var(--text-tertiary); margin-bottom: 10px;
    font-size: 12px; padding-left: 12px;
  }
  .toc ul {
    list-style: none; padding: 0; margin: 0;
    border-left: 0.5px solid var(--border-light);
  }
  .toc a {
    display: block;
    padding: 6px 0 6px 14px;
    color: var(--text-tertiary);
    line-height: 1.45;
    transition: color 0.2s, padding 0.25s;
    cursor: pointer;
    border-left: 1.5px solid transparent;
    margin-left: -1px;
  }
  .toc a:hover { color: var(--text-primary); padding-left: 18px; }
  .toc a.active {
    color: var(--brand);
    border-left-color: var(--brand);
    font-weight: 500;
  }

  .article {
    max-width: 600px; margin: 0 auto;
  }

  .back {
    font-size: 12px; color: var(--text-tertiary);
    margin: 0 0 3rem; display: inline-block;
    cursor: pointer;
    transition: color 0.2s, transform 0.3s cubic-bezier(.34,1.56,.64,1);
    font-family: var(--font-serif); font-style: italic;
  }
  .back:hover { color: var(--text-primary); transform: translateX(-3px); }

  .head {
    text-align: center;
    margin-bottom: 2.5rem; padding-bottom: 2.5rem;
    border-bottom: 0.5px solid var(--border-light);
  }
  .kicker {
    font-family: var(--font-serif); font-style: italic;
    font-size: 13px; color: var(--text-tertiary);
    margin-bottom: 14px;
  }
  .title {
    font-size: 32px; line-height: 1.25; margin: 0 0 18px;
    font-weight: 500; letter-spacing: -0.025em;
    max-width: 500px; margin-left: auto; margin-right: auto;
  }
  .meta {
    font-size: 12px; color: var(--text-tertiary);
    display: flex; justify-content: center;
    gap: 12px; align-items: center; flex-wrap: wrap;
  }
  .meta .tag {
    background: var(--brand-bg-warm);
    color: #633806;
    padding: 2px 8px; border-radius: 2px; font-size: 11px;
  }
  .sep { opacity: 0.5; }

  .note {
    font-family: var(--font-serif); font-style: italic;
    font-size: 14.5px; color: var(--text-secondary);
    line-height: 1.75; text-align: center;
    max-width: 420px; margin: 0 auto 3rem; padding: 0 1rem;
  }
  .note::before, .note::after {
    content: '"';
    font-size: 36px; color: var(--text-tertiary);
    font-family: var(--font-serif); opacity: 0.4;
    line-height: 0; position: relative; top: 10px;
  }
  .note::before { margin-right: 6px; }
  .note::after { margin-left: 4px; }

  /* 正文 */
  .body {
    font-size: 16px; line-height: 1.85;
    color: var(--text-primary);
  }
  .body :global(p) { margin: 0 0 1.4rem; }
  .body :global(> p:first-child::first-letter) {
    font-family: var(--font-serif);
    font-size: 52px;
    font-weight: 500;
    float: left;
    line-height: 0.9;
    margin: 8px 8px 0 -2px;
    color: var(--brand);
  }
  .body :global(h2) {
    font-size: 20px; font-weight: 500;
    margin: 2.5rem 0 1rem;
    letter-spacing: -0.01em; position: relative;
    padding-left: 18px; scroll-margin-top: 20px;
  }
  .body :global(h2::before) {
    content: ''; position: absolute;
    left: 0; top: 50%; transform: translateY(-50%);
    width: 8px; height: 8px;
    background: var(--brand); border-radius: 50%;
  }
  .body :global(h3) {
    font-size: 17px; font-weight: 500;
    margin: 2rem 0 0.75rem;
    color: var(--text-primary);
  }
  .body :global(strong), .body :global(b) {
    font-weight: 500;
    background: linear-gradient(180deg, transparent 65%, var(--brand-bg-warm) 65%);
    padding: 0 2px;
  }
  .body :global(em) {
    font-family: var(--font-serif); font-style: italic;
    color: var(--text-secondary);
  }
  .body :global(blockquote) {
    border-left: 2px solid var(--brand);
    padding: 4px 0 4px 18px;
    margin: 1.8rem 0;
    font-family: var(--font-serif); font-style: italic;
    font-size: 16px; color: var(--text-secondary);
    line-height: 1.8;
  }
  .body :global(blockquote p) { margin: 0; }
  .body :global(code) {
    font-family: var(--font-mono); font-size: 13.5px;
    background: var(--brand-bg);
    padding: 1px 6px; border-radius: 2px;
    color: var(--brand-darker);
  }
  .body :global(pre) {
    background: var(--brand-bg) !important;
    border-radius: 4px; padding: 14px 16px;
    margin: 1.5rem 0; overflow-x: auto;
    font-family: var(--font-mono); font-size: 13px;
    line-height: 1.7;
    border-left: 2px solid var(--border-mid);
  }
  .body :global(pre code) { background: none; padding: 0; color: var(--text-primary); }
  .body :global(hr) {
    border: none; text-align: center; margin: 2.5rem 0;
  }
  .body :global(hr::before) {
    content: '· · ·';
    color: var(--text-tertiary);
    letter-spacing: 0.5em; font-size: 14px;
  }
  .body :global(ul), .body :global(ol) {
    padding-left: 1.25rem;
    margin: 1rem 0 1.4rem;
  }
  .body :global(li) { margin: 0.4rem 0; }
  .body :global(a) {
    color: var(--brand);
    border-bottom: 0.5px solid var(--brand);
    transition: opacity 0.2s;
  }
  .body :global(a:hover) { opacity: 0.7; }
  .body :global(img) {
    border-radius: 2px;
    margin: 1.5rem auto;
  }

  .end {
    text-align: center; margin: 3rem 0 2rem;
  }
  .end-mark {
    display: inline-block; width: 6px; height: 6px;
    background: var(--text-primary);
    transform: rotate(45deg);
    margin: 0 2px; vertical-align: middle;
  }

  .signoff {
    text-align: center;
    margin: 2rem 0 3rem; padding: 1.5rem;
    background: var(--brand-bg); border-radius: 2px;
    font-family: var(--font-serif); font-style: italic;
    font-size: 14.5px; color: var(--brand-darker);
    line-height: 1.7;
  }
  .signoff-name {
    font-family: var(--font-script); font-style: normal;
    font-size: 20px; color: var(--text-primary);
    transform: rotate(-2deg); display: inline-block;
    margin-left: 4px;
  }

  .prev-next {
    border-top: 0.5px solid var(--border-light);
    padding: 1.5rem 0 2.5rem;
    display: flex; justify-content: space-between;
    gap: 20px; font-size: 13px;
  }
  .prev-next-side {
    flex: 1;
    padding: 12px; border-radius: 2px;
    transition: background 0.25s, transform 0.3s;
    color: inherit;
  }
  .prev-next-side:hover { background: var(--brand-bg); }
  .prev-next-side.prev:hover { transform: translateX(-3px); }
  .prev-next-side.next { text-align: right; }
  .prev-next-side.next:hover { transform: translateX(3px); }
  .label {
    font-size: 11px; color: var(--text-tertiary);
    margin-bottom: 4px;
    font-family: var(--font-serif); font-style: italic;
  }
  .pn-title {
    font-weight: 500; line-height: 1.4;
    color: var(--text-primary);
  }
</style>

<script>
  (function() {
    // 阅读进度
    const progress = document.getElementById('progress');
    function updateProgress() {
      const article = document.querySelector('.article');
      if (!article || !progress) return;
      const rect = article.getBoundingClientRect();
      const total = rect.height - window.innerHeight;
      const scrolled = Math.max(0, -rect.top);
      const pct = total > 0 ? Math.min(100, (scrolled / total) * 100) : 0;
      progress.style.width = pct + '%';
    }
    window.addEventListener('scroll', updateProgress, { passive: true });
    updateProgress();

    // 目录 scrollspy
    const tocLinks = document.querySelectorAll<HTMLAnchorElement>('.toc a[data-target]');
    if (tocLinks.length === 0) return;
    const headingEls: HTMLElement[] = [];
    tocLinks.forEach(a => {
      const id = a.getAttribute('data-target');
      if (id) {
        const el = document.getElementById(id);
        if (el) headingEls.push(el);
      }
    });

    // 平滑滚动
    tocLinks.forEach(a => {
      a.addEventListener('click', (e) => {
        e.preventDefault();
        const id = a.getAttribute('data-target');
        if (!id) return;
        const el = document.getElementById(id);
        if (el) {
          const top = el.getBoundingClientRect().top + window.scrollY - 20;
          window.scrollTo({ top, behavior: 'smooth' });
        }
      });
    });

    function spy() {
      const scrollY = window.scrollY + 80;
      let activeId: string | null = headingEls[0]?.id ?? null;
      headingEls.forEach(el => {
        if (el.offsetTop <= scrollY) activeId = el.id;
      });
      tocLinks.forEach(a => {
        a.classList.toggle('active', a.getAttribute('data-target') === activeId);
      });
    }
    window.addEventListener('scroll', spy, { passive: true });
    spy();
  })();
</script>
