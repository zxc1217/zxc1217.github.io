---
// 头像：眼睛会跟鼠标，每隔几秒眨眼一下
---

<div class="avatar" id="avatar">
  <svg viewBox="0 0 56 56" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    <circle cx="28" cy="28" r="25" fill="none" stroke="#2C2C2A" stroke-width="1.2" stroke-dasharray="0.8 1.6" opacity="0.55"/>
    <circle cx="28" cy="24" r="9" fill="none" stroke="#2C2C2A" stroke-width="1.3"/>
    <path d="M 13 50 Q 28 35 43 50" fill="none" stroke="#2C2C2A" stroke-width="1.3" stroke-linecap="round"/>
    <circle class="eye" id="eye-l" cx="24.5" cy="23" r="1" fill="#2C2C2A"/>
    <circle class="eye" id="eye-r" cx="31.5" cy="23" r="1" fill="#2C2C2A"/>
    <path d="M 24.5 27.5 Q 28 30 31.5 27.5" fill="none" stroke="#2C2C2A" stroke-width="1" stroke-linecap="round"/>
  </svg>
</div>

<style>
  .avatar {
    width: 56px;
    height: 56px;
    margin: 0 auto 1.25rem;
    cursor: pointer;
    transition: transform 0.5s cubic-bezier(.34,1.56,.64,1);
  }
  .avatar:hover { transform: rotate(-6deg) scale(1.08); }
  .avatar svg { width: 100%; height: 100%; overflow: visible; }
  .eye { transition: cx 0.15s ease-out, cy 0.15s ease-out; }
</style>

<script>
  (function() {
    const avatar = document.getElementById('avatar');
    const eyeL = document.getElementById('eye-l');
    const eyeR = document.getElementById('eye-r');
    if (!avatar || !eyeL || !eyeR) return;

    const baseLx = 24.5, baseLy = 23, baseRx = 31.5, baseRy = 23;
    const maxShift = 1.3;

    document.addEventListener('mousemove', function(e) {
      const rect = avatar.getBoundingClientRect();
      const cx = rect.left + rect.width / 2;
      const cy = rect.top + rect.height / 2;
      const dx = e.clientX - cx;
      const dy = e.clientY - cy;
      const dist = Math.sqrt(dx*dx + dy*dy);
      if (dist < 0.1) return;
      const shift = Math.min(maxShift, dist / 400);
      const nx = (dx / dist) * shift;
      const ny = (dy / dist) * shift;
      eyeL.setAttribute('cx', (baseLx + nx).toFixed(2));
      eyeL.setAttribute('cy', (baseLy + ny).toFixed(2));
      eyeR.setAttribute('cx', (baseRx + nx).toFixed(2));
      eyeR.setAttribute('cy', (baseRy + ny).toFixed(2));
    });

    // 偶尔眨眼
    function blink() {
      eyeL.style.transition = 'r 0.08s';
      eyeR.style.transition = 'r 0.08s';
      eyeL.setAttribute('r', '0.15');
      eyeR.setAttribute('r', '0.15');
      setTimeout(function() {
        eyeL.setAttribute('r', '1');
        eyeR.setAttribute('r', '1');
      }, 120);
      setTimeout(blink, 3000 + Math.random() * 4000);
    }
    setTimeout(blink, 2500);
  })();
</script>
